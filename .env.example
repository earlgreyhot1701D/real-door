# Copy to .env.local. NEVER commit real keys. NEVER prefix a secret with NEXT_PUBLIC_.
# All credentials are read server-side only (API routes), never shipped to the client.

# --- Amazon Bedrock ---
AWS_REGION=us-east-1

# Cross-region inference profile ID. Models are auto-enabled; no manual "Model access" step needed.
# Verified active as of July 2026. Run `aws bedrock list-inference-profiles` to confirm.
# Options (us-east-1):
#   us.anthropic.claude-sonnet-4-6              (recommended, latest mid-tier)
#   us.anthropic.claude-sonnet-4-5-20250929-v1:0
#   us.anthropic.claude-sonnet-5
# Note: claude-sonnet-4-20250514-v1:0 is Legacy-locked if unused 30+ days. Avoid it.
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6

# Auth uses the default AWS credential chain (in priority order):
# 1. AWS_BEARER_TOKEN_BEDROCK — Bedrock API key (simplest for Vercel). Generate in Bedrock console → API keys.
# 2. AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY — IAM user long-term keys (legacy approach).
# 3. ~/.aws/credentials [default] profile — for local dev (no env vars needed).
# 4. IAM role — for AWS-native deploy (Amplify/App Runner/Lambda).
#
# For Vercel: set ONLY AWS_BEARER_TOKEN_BEDROCK. No IAM user or access keys required.
# AWS_BEARER_TOKEN_BEDROCK=
#
# Legacy (IAM user keys) — only if NOT using the Bedrock API key above:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Set to 1 to skip real Bedrock calls (returns fixed mock JSON). Unset or 0 for production.
USE_MOCK_MODEL=1

# Discover stretch goal — transparent property lookup from public sources
TAVILY_API_KEY=

# App origin, used to lock CORS on API routes. Set to your Vercel URL in production.
APP_ORIGIN=http://localhost:3000
